<?xml version="1.0" encoding="utf-8"?>
<!--
    🧾【每日明細項目】- item_detail.xml

    想像你去超商買東西，拿到的發票明細：

    ┌─────────────────────────────────────────────────────────┐
    │  ┌────┐                                                │
    │  │3/1 │  加油                            NT$ 125      │
    │  └────┘                                                │
    │                                                        │
    │  ┌────┐                                                │
    │  │3/1 │  午餐                            NT$ 150      │
    │  └────┘                                                │
    │                                                        │
    │  ┌────┐                                                │
    │  │3/2 │  捷運                              NT$ 30      │
    │  └────┘                                                │
    └─────────────────────────────────────────────────────────┘

    每一列就是「一筆交易的明細」，包含：
    - 📅 左邊：日期標籤（圓角背景，例如「3/1」）
    - 📝 中間：項目名稱（例如「加油」、「午餐」）
    - 💰 右邊：金額（紅色表示支出，綠色表示收入）

    使用位置：
    - 「分析」頁面的分類明細
    - 「首頁」頁面的交易列表（可能用類似樣式）
-->

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_analysis_list_item"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <!--
        ========== 📅 左邊：日期標籤（圓角徽章） ==========

        這是一個圓角矩形的日期標籤
        例如：「3/1」、「3/2」、「4/15」

        就像發票上的日期戳記一樣～

        設計細節：
        - 寬度 58dp：固定寬度，日期不會忽大忽小
        - 高度 32dp：夠高好點擊（雖然不能點）
        - 圓角背景：bg_analysis_date_chip（像晶片一樣的造型）
        - 橘褐色文字：#A65B34（溫暖的提醒色）
        - 文字置中 + 粗體：讓日期更醒目
    -->
    <TextView
    android:id="@+id/tvDetailDate"
    android:layout_width="58dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_analysis_date_chip"
        android:gravity="center"
        android:text="3/1"
        android:textColor="#A65B34"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!--
        ========== 📝 中間：項目名稱（交易標題） ==========

        顯示這筆交易的「內容」
        例如：「加油」、「午餐」、「薪水」

        設計細節：
        - layout_width="0dp" + weight="1"：佔滿剩餘空間
        - 這樣不管螢幕多寬，左邊日期和右邊金額的位置都會固定
        - 名稱永遠在中間區域

        layout_marginStart="12dp"：與左邊日期間隔 12dp（呼吸空間）
    -->
    <TextView
    android:id="@+id/tvDetailTitle"
    android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:text="加油"
        android:textColor="#1E1E2A"
        android:textSize="14sp"
        android:textStyle="bold" />
    <!--
        ========== 💰 右邊：金額 ==========

        顯示這筆交易的金額
        例如：「NT$ 125」、「NT$ 150」

        顏色設計：
        - 支出（紅色 #C62828）：警告、花錢的感覺
        - 收入（綠色 #2E7D32）：開心、賺錢的感覺
        - （顏色由程式碼動態設定，這裡預設紅色）

        注意：沒有用 layout_weight，所以寬度是 wrap_content
        這讓金額會自動靠右（因為中間的名稱把空間吃掉了）
    -->
    <TextView
    android:id="@+id/tvDetailAmount"
    android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NT$ 125"
        android:textColor="#C62828"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- 設計說明：左側日期固定寬度，中間標題使用 weight 撐開，右側金額依收入/支出切換顏色。 -->
</LinearLayout>
