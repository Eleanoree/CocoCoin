<?xml version="1.0" encoding="utf-8"?>
<!-- 首頁：
    上半部：月份總覽卡片（結餘、支出、收入、預算進度條）
    下半部：交易紀錄卡片（RecyclerView 顯示最近交易） -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6EFE8">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FFFDFB"
            android:elevation="2dp"
            app:cardCornerRadius="22dp"
            app:cardUseCompatPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    style="@style/TextAppearance.CocoCoin.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_analysis_section_badge"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="月份總覽"
                    android:textColor="#A65B34"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvBalanceLabel"
                    style="@style/TextAppearance.CocoCoin.SupportText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="當月結餘"
                    android:textColor="#8C8B97"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvMonthlyBalance"
                        style="@style/TextAppearance.CocoCoin.MetricHero"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NT$ 0"
                        android:textColor="#1E1E2A"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_record_date_selector"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="6dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="6dp"
                        android:paddingBottom="5dp">

                        <TextView
                            android:id="@+id/btnPreviousMonth"
                            style="@style/TextAppearance.CocoCoin.BodyStrong"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:gravity="center"
                            android:text="‹"
                            android:textColor="#A65B34"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/tvSelectedMonth"
                            style="@style/TextAppearance.CocoCoin.BodyStrong"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:text="2026 年 3 月"
                            android:textColor="#6B625D"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/btnNextMonth"
                            style="@style/TextAppearance.CocoCoin.BodyStrong"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:gravity="center"
                            android:text="›"
                            android:textColor="#A65B34"
                            android:textSize="18sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_analysis_stat_expense"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvExpenseLabel"
                        style="@style/TextAppearance.CocoCoin.SupportText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="當月支出"
                        android:textColor="#8C8B97"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvMonthlyExpense"
                        style="@style/TextAppearance.CocoCoin.MetricMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="NT$ 0"
                        android:textColor="#C62828"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_analysis_stat_income"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvIncomeLabel"
                        style="@style/TextAppearance.CocoCoin.SupportText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="當月收入"
                        android:textColor="#8C8B97"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvMonthlyIncome"
                        style="@style/TextAppearance.CocoCoin.MetricMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="NT$ 0"
                        android:textColor="#2E7D32"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_analysis_detail_panel"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvBudgetLabel"
                        style="@style/TextAppearance.CocoCoin.SupportText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="當月預算"
                        android:textColor="#8C8B97"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvBudgetPercent"
                        style="@style/TextAppearance.CocoCoin.Badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_analysis_section_badge"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="剩餘 0%"
                        android:textColor="#A65B34"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.CocoCoin.MetaLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="預算總額"
                            android:textColor="#9A8F87"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvMonthlyBudget"
                            style="@style/TextAppearance.CocoCoin.MetricMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="NT$ 0"
                            android:textColor="#1E1E2A"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvRemainingLabel"
                            style="@style/TextAppearance.CocoCoin.MetaLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="當月可用"
                            android:textColor="#9A8F87"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvRemainingBudget"
                            style="@style/TextAppearance.CocoCoin.MetricMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="NT$ 0"
                            android:textColor="#2E7D32"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBudget"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="0"
                    android:progressBackgroundTint="#E9DED2"
                    android:progressTint="#8D6E63" />
            </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardTransactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="#FFFDFB"
            android:elevation="2dp"
            app:cardCornerRadius="22dp"
            app:cardUseCompatPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/TextAppearance.CocoCoin.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_analysis_section_badge"
                    android:paddingStart="10dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="6dp"
                    android:text="交易紀錄"
                    android:textColor="#A65B34"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTransactionsMonth"
                    style="@style/TextAppearance.CocoCoin.MetaLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="2026 年 3 月"
                    android:textColor="#9A8F87"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvEmptyTransaction"
                style="@style/TextAppearance.CocoCoin.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_analysis_summary"
                android:gravity="center"
                android:padding="16dp"
                android:text="尚無記帳資料"
                android:textColor="#9A98A6"
                android:textSize="15sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTransactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <ImageButton
        android:id="@+id/btnScrollToTop"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_scroll_to_top_button"
        android:contentDescription="回到頂端"
        android:elevation="6dp"
        android:alpha="0"
        android:padding="10dp"
        android:scaleX="0.92"
        android:scaleY="0.92"
        android:scaleType="centerInside"
        android:src="@android:drawable/arrow_up_float"
        android:tint="#8B7666"
        android:visibility="gone" />

</FrameLayout>
