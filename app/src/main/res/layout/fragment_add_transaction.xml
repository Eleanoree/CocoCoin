<?xml version="1.0" encoding="utf-8"?>
<!--
    記帳頁面：
    包含 『日期、金額、支出/收入切換、分類、帳戶、備註、數字鍵盤、儲存/取消按鈕』
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F1EC"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvType"
            style="@style/TextAppearance.CocoCoin.CardTitleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="支出"
            android:textColor="#C62828"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNt"
            style="@style/TextAppearance.CocoCoin.MetricHero"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="NT$ "
            android:textColor="#C62828"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAmount"
            style="@style/TextAppearance.CocoCoin.MetricHero"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="0"
            android:textColor="#C62828"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCurrentTime"
            style="@style/TextAppearance.CocoCoin.BodyStrong"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_add_transaction_date_selector"
            android:drawableStart="@android:drawable/ic_menu_my_calendar"
            android:drawableEnd="@android:drawable/arrow_down_float"
            android:drawablePadding="4dp"
            android:drawableTint="#8D7A69"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text=""
            android:textColor="#675C53"
            android:textSize="13sp" />
    </LinearLayout>

    <RadioGroup
        android:id="@+id/rgType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbExpense"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="支出"
            android:textColor="#1F2A37"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/rbIncome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="收入"
            android:textColor="#1F2A37"
            android:textSize="15sp" />
    </RadioGroup>

    <!-- 資訊卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:padding="9dp">

        <!-- 類別 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:padding="6dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="#7A7A7A"
                tools:ignore="UseAppTint" />

            <TextView
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="類別"
                android:textColor="#5E5E5E"
                android:textSize="15sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="選擇分類"
                app:boxBackgroundColor="#F6F2EC"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="#E2DBD1"
                app:endIconMode="dropdown_menu">

                <AutoCompleteTextView
                    android:id="@+id/actCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="false"
                    android:inputType="none"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:textColor="#2E2A2A"
                    android:textSize="15sp"
                    tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
        <!-- 帳戶 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:padding="6dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:tint="#7A7A7A"
                tools:ignore="UseAppTint" />

            <TextView
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="帳戶"
                android:textColor="#5E5E5E"
                android:textSize="15sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="選擇帳戶"
                app:boxBackgroundColor="#F6F2EC"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="#E2DBD1"
                app:endIconMode="dropdown_menu">

                <AutoCompleteTextView
                    android:id="@+id/actAccount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="false"
                    android:inputType="none"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:textColor="#2E2A2A"
                    android:textSize="15sp"
                    tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
        <!-- 備註 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:padding="6dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_edit" />

            <TextView
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="備註"
                android:textColor="#374151"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etNote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="新增備註"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:textColor="#1F2A37"
                android:textSize="15sp"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>
    </LinearLayout>

    <!-- Keypad -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="35dp"
        android:columnCount="3"
        android:rowCount="4"
        android:useDefaultMargins="true">

        <Button
            android:id="@+id/btn1"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#CAC1AF"
            android:text="1"
            android:textColor="#2E2A2A"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btn2"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#CAC1AF"
            android:text="2"
            android:textColor="#2E2A2A"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btn3"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#CAC1AF"
            android:text="3"
            android:textColor="#2E2A2A"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btn4"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#CAC1AF"
            android:text="4"
            android:textColor="#2E2A2A"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btn5"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#CAC1AF"
            android:text="5"
            android:textColor="#2E2A2A"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btn6"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#CAC1AF"
            android:text="6"
            android:textColor="#2E2A2A"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btn7"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#CAC1AF"
            android:text="7"
            android:textColor="#2E2A2A"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btn8"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#CAC1AF"
            android:text="8"
            android:textColor="#2E2A2A"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btn9"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#CAC1AF"
            android:text="9"
            android:textColor="#2E2A2A"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#CAC1AF"
            android:text="C"
            android:textColor="#2E2A2A"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btn0"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#CAC1AF"
            android:text="0"
            android:textColor="#2E2A2A"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#CAC1AF"
            android:text="⌫"
            android:textColor="#2E2A2A"
            android:textSize="18sp" />
    </GridLayout>

    <!-- 底部按鈕 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="0dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:backgroundTint="#7E786C"
            android:text="Cancel"
            android:textColor="#FDF5F5"
            android:textSize="17sp" />

        <Space
            android:layout_width="12dp"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:backgroundTint="#DBBB80"
            android:text="Save"
            android:textColor="#2E2A2A"
            android:textSize="17sp" />
    </LinearLayout>

</LinearLayout>
