<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     📋 交易列表項目佈局 — 白話文：記帳本每一筆帳的「小卡片設計圖」
     ============================================================

     情境劇：想像你在記帳本首頁，看到一排排的小卡片：

       ┌─────────────────────────────────────────────┐
       │ 支 │ 餐飲                      -NT$ 100    │
       │   │ 2025/03/22 11:25                       │
       │   │ [國泰銀行]                             │
       │   │ 雞排加辣                               │
       └─────────────────────────────────────────────┘

     這個 XML 檔案就是那張「小卡片」的設計圖！
     每一筆交易都會用這個模板來顯示
     ============================================================
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_analysis_list_item"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <!-- ============================================================
         🔴 左邊區域：類型圖示（支出／收入的小圓圈）
         ============================================================
         這個小圓圈用來快速區分這筆是「收入」還是「支出」
           - 支出：紅色底 + 「支」字 ❤️
           - 收入：綠色底 + 「收」字 💚
    -->
    <LinearLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="#F1ECE6"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTypeIcon"
            style="@style/TextAppearance.CocoCoin.Tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="支"
            android:textColor="#C62828"
            android:textSize="14sp"
            android:textStyle="bold" />
        <!-- 注意：text 只是一個範例文字「支」，真正顯示時會根據收入/支出改成「收」或「支」 -->
    </LinearLayout>

    <!-- ============================================================
         📝 中間區域：交易詳細資訊（垂直排列）
         ============================================================
         這裡顯示一筆交易的「內容」，從上到下依序是：
           1. 分類名稱（例如「餐飲」）
           2. 時間（例如「2025/03/22 11:25」）
           3. 帳戶標籤（例如「國泰銀行」）
           4. 備註（如果有寫的話，例如「雞排加辣」）
    -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- ============================================================
             🏷️ 分類名稱 — 白話文：花了什麼？（餐飲、交通、購物...）
             ============================================================
        -->
        <TextView
            android:id="@+id/tvCategory"
            style="@style/TextAppearance.CocoCoin.ListTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="餐飲"
            android:textColor="#1E1E2A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- ============================================================
             🕐 時間 — 白話文：什麼時候花的？（例如「2025/03/22 11:25」）
             ============================================================
        -->
        <TextView
            android:id="@+id/tvTime"
            style="@style/TextAppearance.CocoCoin.SupportText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="2025/03/22 11:25"
            android:textColor="#9A98A6"
            android:textSize="12sp" />

        <!-- ============================================================
             🏷️ 帳戶標籤 — 白話文：錢從哪個帳戶進出？
             ============================================================
             這是一個橢圓形的小標籤，裡面顯示帳戶名稱（例如「國泰銀行」）
             不同帳戶類型會有不同顏色：
               - 現金：黃色系 💛
               - 信用卡：紫色系 💜
               - 銀行：藍色系 💙
               - 電子支付：綠色系 💚
        -->
        <LinearLayout
            android:id="@+id/layoutAccountTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:background="@drawable/bg_account_tag"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp">

            <TextView
                android:id="@+id/tvAccountName"
                style="@style/TextAppearance.CocoCoin.Tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="國泰銀行"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ============================================================
             📝 備註 — 白話文：使用者額外寫的「小紙條」
             ============================================================
             如果使用者有寫備註（例如「雞排加辣」），這裡會顯示
             如果沒寫，這整行會隱藏（不佔空間）

             android:visibility="gone" 表示：
               - 不會顯示
               - 也不佔據畫面上的空間（旁邊的內容會擠過來）

             另一種寫法是 android:visibility="invisible"
               那是「隱藏但還佔著空間」（留一個空白）
             我們希望沒備註時，時間和金額能靠比較近，所以用 "gone"
        -->
        <TextView
            android:id="@+id/tvNote"
            style="@style/TextAppearance.CocoCoin.SupportText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text=""
            android:textColor="#B0A9A2"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ============================================================
         💰 右邊區域：金額 — 白話文：花了多少錢或賺了多少錢？
         ============================================================
         金額的顏色和符號會根據類型改變：
           - 支出：紅色 ❤️ + 負號（例如「-NT$ 100」）
           - 收入：綠色 💚 + 正號（例如「+NT$ 50,000」）
    -->
    <TextView
        android:id="@+id/tvAmount"
        style="@style/TextAppearance.CocoCoin.MetricMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="-NT$ 100"
        android:textColor="#C62828"
        android:textSize="15sp"
        android:textStyle="bold" />

    <!-- 注意：text 只是範例文字，真正顯示時會根據實際金額和類型調整 -->
</LinearLayout>