<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     📊 每日明細項目佈局 — 白話文：分類統計頁面的「交易小卡設計圖」
     ============================================================

     情境劇：想像你在分析頁面，點擊了圓餅圖的「餐飲」分類
             右邊會顯示一排排的詳細交易小卡：

       ┌─────────────────────────────────────────────────────┐
       │ 📝 雞排加辣 (標題)                      💰 -NT$ 100 │
       │    🏷️ 餐飲 ・ 現金 (副標題)                        │
       └─────────────────────────────────────────────────────┘
       ┌─────────────────────────────────────────────────────┐
       │ 📝 麥當勞 (標題)                         💰 -NT$ 200 │
       │    🏷️ 餐飲 ・ 信用卡 (副標題)                       │
       └─────────────────────────────────────────────────────┘

     這個 XML 檔案就是那張「交易小卡」的設計圖！
     每一筆該分類的交易都會用這個模板來顯示

     注意！這個佈局和首頁的 item_transaction.xml 不同：
       - 首頁的卡片：顯示「收/支圓圈、分類、時間、帳戶標籤、備註」
       - 這裡的卡片：顯示「交易標題 + 副標題 + 金額」（精簡版）
         （因為站在分析頁面，使用者已經知道這是「支出」類別了）
     ============================================================
-->

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_analysis_list_item"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <!--
            android:layout_weight="1":
            佔掉剩下的所有空間 讓金額永遠乖乖待在最右邊
        -->
        <TextView
            android:id="@+id/tvDailyDetailTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="加油"
            android:textColor="#1E1E2A"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDailyDetailSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="交通 ・ 現金"
            android:textColor="#8C8B97"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDailyDetailAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="-NT$ 125"
        android:textColor="#C62828"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
