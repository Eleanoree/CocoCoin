<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     🏷️ 編輯分類對話框內容佈局 — 白話文：新增/編輯分類的「表單設計圖」
     ============================================================

     情境劇：想像你在設定頁面點擊「管理分類」，然後點擊「新增支出種類」：

       ╭─────────────────────────────────────────╮
       │  ┌─────────────────────────────────┐   │
       │  │       🍽 選擇 icon              │   │  ← 點擊可選 emoji
       │  └─────────────────────────────────┘   │
       │                                         │
       │  ┌─────────────────────────────────┐   │
       │  │ 輸入分類名稱                     │   │
       │  │ 餐飲                            │   │
       │  └─────────────────────────────────┘   │
       │                                         │
       │         [ 儲存 ]   [ 取消 ]             │
       ╰─────────────────────────────────────────╯

     這個 XML 檔案就是那張「表單」的設計圖！
     使用者可以在這裡：
       - 點擊「選擇 icon」按鈕 → 跳出 emoji 選單（🍽、🚗、💰...）
       - 在輸入框輸入分類名稱（例如「餐飲」、「手搖飲」）
       - 點擊「儲存」完成新增/編輯
       - 點擊「取消」放棄修改

     注意：按鈕是在程式碼中動態加入的哦！
     ============================================================
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <Button
        android:id="@+id/btnPickCategoryIcon"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="5dp"
        android:background="@drawable/bg_settings_button_secondary"
        android:backgroundTint="@null"
        android:text="自訂 icon"
        android:textAllCaps="false"
        android:textColor="#6E564F"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@null"
        tools:ignore="TouchTargetSizeCheck" />

    <EditText
        android:id="@+id/etCategoryName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="12dp"
        android:layout_marginRight="5dp"
        android:background="@drawable/bg_analysis_input"
        android:hint="輸入分類名稱"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp"
        android:textColor="#2F2A27"
        android:textSize="15sp" />

</LinearLayout>
