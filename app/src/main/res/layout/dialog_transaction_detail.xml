<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="#FFF9F4"> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="交易詳情"
    android:textSize="20sp"
    android:textStyle="bold"
    android:textColor="#A65B34" /> <View
    android:layout_width="40dp"
    android:layout_height="3dp"
    android:layout_marginTop="8dp"
    android:background="#DBBB80" /> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="24dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvDetailType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="類型：支出"
        android:textSize="15sp"
        android:textColor="#C62828" />

    <TextView
        android:id="@+id/tvDetailCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="分類：餐飲"
        android:textSize="15sp"
        android:textColor="#4B5563" />

    <TextView
        android:id="@+id/tvDetailAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="金額：NT$ 100"
        android:textColor="#2E2A2A"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDetailAccount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="帳戶：現金"
        android:textSize="15sp"
        android:textColor="#4B5563" />

    <TextView
        android:id="@+id/tvDetailNote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="備註：午餐"
        android:textSize="15sp"
        android:textColor="#4B5563" />

    <TextView
        android:id="@+id/tvDetailDateTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="2026/03/26 16:02"
        android:textSize="13sp"
        android:textColor="#9CA3AF" />
</LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnDelete"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:backgroundTint="#E4C3BD"
            android:text="刪除"
            android:textColor="#C62828" />

        <Button
            android:id="@+id/btnEdit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1.2"
            android:layout_marginStart="12dp"
            android:backgroundTint="#DBBB80"
            android:text="編輯"
            android:textColor="#2E2A2A"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>
</LinearLayout>