<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     📧 Email 登入憑證對話框 — 白話文：信箱登入的「彈出視窗設計圖」
     ============================================================

     情境劇：想像你在設定頁面點擊「信箱登入」，然後跳出一個小視窗：

       ╭─────────────────────────────────────────╮
       │                                         │
       │  ┌─────────────────────────────────┐   │
       │  │ 電子郵件                        │   │
       │  │ user@example.com                │   │
       │  └─────────────────────────────────┘   │
       │                                         │
       │  ┌─────────────────────────────────┐   │
       │  │ 密碼                    👁️      │   │
       │  │ ••••••••                       │   │
       │  └─────────────────────────────────┘   │
       │                                         │
       │         [ 登入 ]   [ 取消 ]             │
       │                                         │
       ╰─────────────────────────────────────────╯

     這個 XML 檔案就是那張「登入表單」的設計圖！
     使用者可以在這裡：
       - 輸入 Email 地址
       - 輸入密碼（點擊眼睛圖示可以切換顯示/隱藏）
       - 點擊「登入」按鈕執行登入
       - 點擊「取消」關閉視窗

     注意：這個檔案只包含「輸入框」部分，按鈕是在程式碼中動態加入的！
     ============================================================
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 標題列 -->

        <!-- 分隔線（乾淨的一條線，沒有模糊效果） -->

        <!-- 副標題 -->

        <!-- Email 輸入框（乾淨背景，無模糊圖片） -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="電子郵件"
            android:textColorHint="#B0A9A2"
            app:boxStrokeColor="#D4C9BE"
            app:boxStrokeWidth="1dp"
            app:hintTextColor="#9A8F87">

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:maxLines="1"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="#2E2A2A"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 密碼輸入框（乾淨背景，無模糊圖片） -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="密碼"
            android:textColorHint="#B0A9A2"
            app:boxStrokeColor="#D4C9BE"
            app:boxStrokeWidth="1dp"
            app:endIconMode="password_toggle"
            app:endIconTint="#9A8F87"
            app:hintTextColor="#9A8F87">

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="#2E2A2A"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvRegisterHint"
            style="@style/TextAppearance.CocoCoin.SupportText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text=""
            android:textColor="#C14B45"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
