<?xml version="1.0" encoding="utf-8"?>
<!--
    Email 登入憑證對話框：讓使用者輸入 Email 和密碼
-->

<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 標題列 -->

        <!-- 分隔線（乾淨的一條線，沒有模糊效果） -->

        <!-- 副標題 -->

        <!-- Email 輸入框（乾淨背景，無模糊圖片） -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="電子郵件"
            android:textColorHint="#B0A9A2"
            app:boxStrokeColor="#D4C9BE"
            app:boxStrokeWidth="1dp"
            app:hintTextColor="#9A8F87">

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:maxLines="1"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="#2E2A2A"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 密碼輸入框（乾淨背景，無模糊圖片） -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="密碼"
            android:textColorHint="#B0A9A2"
            app:boxStrokeColor="#D4C9BE"
            app:boxStrokeWidth="1dp"
            app:endIconMode="password_toggle"
            app:endIconTint="#9A8F87"
            app:hintTextColor="#9A8F87">

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="#2E2A2A"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 登入按鈕（溫暖的橘褐色，不是紫色） -->

        <!-- 註冊提示 -->
        <TextView
            android:id="@+id/tvRegisterHint"
            style="@style/TextAppearance.CocoCoin.SupportText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="還沒有帳號？點此註冊"
            android:textColor="#A65B34"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>