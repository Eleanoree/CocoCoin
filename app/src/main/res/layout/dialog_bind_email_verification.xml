<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="信箱帳號"
            android:textColorHint="#B0A9A2"
            app:boxStrokeColor="#D4C9BE"
            app:boxStrokeWidth="1dp"
            app:hintTextColor="#9A8F87">

            <EditText
                android:id="@+id/etBindEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:maxLines="1"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="#2E2A2A"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="密碼"
            android:textColorHint="#B0A9A2"
            app:boxStrokeColor="#D4C9BE"
            app:boxStrokeWidth="1dp"
            app:endIconMode="password_toggle"
            app:endIconTint="#9A8F87"
            app:hintTextColor="#9A8F87">

            <EditText
                android:id="@+id/etBindPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="#2E2A2A"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="再次輸入密碼"
            android:textColorHint="#B0A9A2"
            app:boxStrokeColor="#D4C9BE"
            app:boxStrokeWidth="1dp"
            app:endIconMode="password_toggle"
            app:endIconTint="#9A8F87"
            app:hintTextColor="#9A8F87">

            <EditText
                android:id="@+id/etBindPasswordConfirm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="#2E2A2A"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnSendEmailCode"
            style="@style/TextAppearance.CocoCoin.Button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_analysis_primary_button"
            android:backgroundTint="@null"
            android:text="寄送驗證信"
            android:textAllCaps="false"
            android:textColor="#FFF8F3"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <TextView
            android:id="@+id/tvEmailCodeHint"
            style="@style/TextAppearance.CocoCoin.SupportText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="寄出後請到信箱開啟驗證信，點擊信中的驗證連結後再回到 App。"
            android:textColor="#8D8178"
            android:textSize="13sp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
