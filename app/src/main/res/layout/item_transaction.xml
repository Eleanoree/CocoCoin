<?xml version="1.0" encoding="utf-8"?>
<!--
    呈現一筆交易的外觀 用在記帳主畫面
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_analysis_list_item"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <!-- ────────── 左邊：類型圖示（支出／收入）────────── -->
    <LinearLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="#F1ECE6"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTypeIcon"
            style="@style/TextAppearance.CocoCoin.Tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="支"
            android:textColor="#C62828"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ────────── 中間：交易詳細資訊（垂直排列）────────── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- 分類名稱：例如「餐飲」「交通」 -->
        <TextView
            android:id="@+id/tvCategory"
            style="@style/TextAppearance.CocoCoin.ListTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="餐飲"
            android:textColor="#1E1E2A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- 時間：例如「2025/03/22 11:25」 -->
        <TextView
            android:id="@+id/tvTime"
            style="@style/TextAppearance.CocoCoin.SupportText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="2025/03/22 11:25"
            android:textColor="#9A98A6"
            android:textSize="12sp" />

        <!-- 帳戶標籤（例如「信用卡」） -->
        <LinearLayout
            android:id="@+id/layoutAccountTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:background="@drawable/bg_account_tag"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp">

            <!-- 帳戶名稱（例如「國泰銀行」） -->
            <TextView
                android:id="@+id/tvAccountName"
                style="@style/TextAppearance.CocoCoin.Tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="國泰銀行"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 備註（預設隱藏，有輸入備註時才顯示） -->
        <TextView
            android:id="@+id/tvNote"
            style="@style/TextAppearance.CocoCoin.SupportText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text=""
            android:textColor="#B0A9A2"
            android:textSize="12sp"
            android:visibility="gone" />
            <!-- visibility="gone" 表示一開始完全隱藏，不佔空間 -->
    </LinearLayout>

    <!-- ────────── 右邊：金額（支出紅色，收入綠色）────────── -->
    <TextView
        android:id="@+id/tvAmount"
        style="@style/TextAppearance.CocoCoin.MetricMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="-NT$ 100"
        android:textColor="#C62828"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
