<?xml version="1.0" encoding="utf-8"?>
<!--
    ✏️【編輯帳戶對話框】- dialog_edit_account.xml

    想像你想修改錢包的名稱或餘額，就會跳出這個小視窗：

    ┌─────────────────────────────────────────────────────────────┐
    │                                                              │
    │  ┌────────────────────────────────────────────────────────┐ │
    │  │  帳戶名稱                                              │ │
    │  │  ┌────────────────────────────────────────────────────┐│ │
    │  │  │  現金                                              ││ │
    │  │  └────────────────────────────────────────────────────┘│ │
    │  └────────────────────────────────────────────────────────┘ │
    │                                                              │
    │  ┌────────────────────────────────────────────────────────┐ │
    │  │  餘額                                                  │ │
    │  │  ┌────────────────────────────────────────────────────┐│ │
    │  │  │  10000                                            ││ │
    │  │  └────────────────────────────────────────────────────┘│ │
    │  └────────────────────────────────────────────────────────┘ │
    │                                                              │
    │  ┌──────────────┐  ┌──────────────┐                        │
    │  │    取消      │  │    儲存      │                        │
    │  └──────────────┘  └──────────────┘                        │
    │                                                              │
    └─────────────────────────────────────────────────────────────┘

    使用情境：
    - 使用者點擊某個帳戶的「編輯」按鈕
    - 跳出這個對話框，裡面已經預填好原本的名稱和餘額
    - 使用者修改後按「儲存」，帳戶資料就更新了！

    特色：
    1️⃣ 乾淨的淺米色背景
    2️⃣ Material Design 3 輸入框樣式
    3️⃣ 金色邊框（#DBBB80），溫暖有質感
    4️⃣ 淺咖啡色提示文字（#8D6E63）
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="#FFF9F4">

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:hint="帳戶名稱"
        app:boxStrokeColor="#DBBB80"
        app:hintTextColor="#8D6E63">

        <!-- 帳戶名稱輸入框 -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEditAccountName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="#2E2A2A" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="餘額"
        app:boxStrokeColor="#DBBB80"
        app:hintTextColor="#8D6E63">

        <!-- 帳戶餘額輸入框 -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEditAccountBalance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="#2E2A2A" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>