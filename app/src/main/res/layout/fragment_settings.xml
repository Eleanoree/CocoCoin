<?xml version="1.0" encoding="utf-8"?>
<!--
    設定頁面：讓使用者管理帳本名稱、雲端同步、帳號安全、資料備份與匯出等功能
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6EFE8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            style="@style/TextAppearance.CocoCoin.PageTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="設定"
            android:textColor="#1E1E2A"
            android:textSize="28sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:backgroundTint="#FFFDFB"
            android:elevation="2dp"
            app:cardCornerRadius="22dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/TextAppearance.CocoCoin.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_analysis_section_badge"
                    android:paddingStart="10dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="6dp"
                    android:text="帳本概況"
                    android:textColor="#A65B34"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/layoutBookNameCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_analysis_stat_balance"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/TextAppearance.CocoCoin.SupportText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="帳本名稱"
                                android:textColor="#8C8B97"
                                android:textSize="12sp" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:contentDescription="可編輯"
                                android:src="@drawable/ic_edit_hint"
                                app:tint="#9C9188" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvBookName"
                            style="@style/TextAppearance.CocoCoin.MetricMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="CocoCoin"
                            android:textColor="#1E1E2A"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_analysis_stat_income"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            style="@style/TextAppearance.CocoCoin.SupportText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="記帳筆數"
                            android:textColor="#8C8B97"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvTransactionCount"
                            style="@style/TextAppearance.CocoCoin.MetricMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0 筆"
                            android:textColor="#2E7D32"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:backgroundTint="#FFFDFB"
            android:elevation="2dp"
            app:cardCornerRadius="22dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/TextAppearance.CocoCoin.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_analysis_section_badge"
                    android:paddingStart="10dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="6dp"
                    android:text="雲端狀態"
                    android:textColor="#A65B34"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_analysis_detail_panel"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="已綁定登入方式"
                        android:textColor="#9A8F87"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvLinkedProviders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_settings_badge_soft"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="尚未綁定任何登入方式"
                        android:textColor="#7A6F68"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_analysis_section_list"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="最近同步"
                        android:textColor="#7C746D"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvLastSync"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="--"
                        android:textColor="#5D5651"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:backgroundTint="#FFFDFB"
            android:elevation="2dp"
            app:cardCornerRadius="22dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/TextAppearance.CocoCoin.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_analysis_section_badge"
                    android:paddingStart="10dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="6dp"
                    android:text="帳號安全"
                    android:textColor="#A65B34"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnPrimaryAccountAction"
                    style="@style/TextAppearance.CocoCoin.Button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_analysis_primary_button"
                    android:backgroundTint="@null"
                    android:text="升級帳號"
                    android:textAllCaps="false"
                    android:textColor="#FFF8F3"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btnSecondaryAccountAction"
                    style="@style/TextAppearance.CocoCoin.Button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_settings_button_secondary"
                    android:backgroundTint="@null"
                    android:text="登入既有帳號"
                    android:textAllCaps="false"
                    android:textColor="#6E564F"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btnEmailAccountAction"
                    style="@style/TextAppearance.CocoCoin.Button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_settings_button_secondary"
                    android:backgroundTint="@null"
                    android:text="綁定信箱"
                    android:textAllCaps="false"
                    android:textColor="#6E564F"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btnUnlinkGoogleAction"
                    style="@style/TextAppearance.CocoCoin.Button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_settings_button_subtle_danger"
                    android:backgroundTint="@null"
                    android:text="解除綁定 Google"
                    android:textAllCaps="false"
                    android:textColor="#8A4F45"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btnUnlinkEmailAction"
                    style="@style/TextAppearance.CocoCoin.Button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_settings_button_subtle_danger"
                    android:backgroundTint="@null"
                    android:text="解除綁定信箱"
                    android:textAllCaps="false"
                    android:textColor="#8A4F45"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btnBackupNow"
                    style="@style/TextAppearance.CocoCoin.Button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_settings_button_success"
                    android:backgroundTint="@null"
                    android:text="立即備份到雲端"
                    android:textAllCaps="false"
                    android:textColor="#47623F"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btnSignOut"
                    style="@style/TextAppearance.CocoCoin.Button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_settings_button_warning"
                    android:backgroundTint="@null"
                    android:text="登出目前帳號"
                    android:textAllCaps="false"
                    android:textColor="#8A4F45"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#FFFBF8"
            android:elevation="1dp"
            app:cardCornerRadius="22dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/TextAppearance.CocoCoin.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_badge_soft"
                    android:paddingStart="10dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="6dp"
                    android:text="資料管理"
                    android:textColor="#8A7B70"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_analysis_detail_panel"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="分類 / 種類管理"
                        android:textColor="#7C746D"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCategorySummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="支出 10 種 · 收入 7 種"
                        android:textColor="#5D5651"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnManageCategories"
                        style="@style/TextAppearance.CocoCoin.Button"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_settings_button_secondary"
                        android:backgroundTint="@null"
                        android:text="管理分類與 icon"
                        android:textAllCaps="false"
                        android:textColor="#6E564F"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null"
                        tools:ignore="TouchTargetSizeCheck" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_analysis_detail_panel"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="自動本機備份"
                        android:textColor="#7C746D"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAutoBackupStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="尚未設定自動本機備份"
                        android:textColor="#5D5651"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnChooseAutoBackupFolder"
                            style="@style/TextAppearance.CocoCoin.Button"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_settings_button_secondary"
                            android:backgroundTint="@null"
                            android:text="選擇資料夾"
                            android:textAllCaps="false"
                            android:textColor="#6E564F"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:backgroundTint="@null"
                            tools:ignore="TouchTargetSizeCheck" />

                        <Button
                            android:id="@+id/btnDisableAutoBackup"
                            style="@style/TextAppearance.CocoCoin.Button"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_settings_button_secondary"
                            android:backgroundTint="@null"
                            android:text="停用"
                            android:textAllCaps="false"
                            android:textColor="#6E564F"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:backgroundTint="@null"
                            tools:ignore="TouchTargetSizeCheck" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnExportData"
                        style="@style/TextAppearance.CocoCoin.Button"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_settings_button_secondary"
                        android:backgroundTint="@null"
                        android:text="匯出備份檔"
                        android:textAllCaps="false"
                        android:textColor="#6E564F"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null"
                        tools:ignore="TouchTargetSizeCheck" />

                    <Button
                        android:id="@+id/btnImportData"
                        style="@style/TextAppearance.CocoCoin.Button"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_settings_button_secondary"
                        android:backgroundTint="@null"
                        android:text="匯入備份檔"
                        android:textAllCaps="false"
                        android:textColor="#6E564F"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null"
                        tools:ignore="TouchTargetSizeCheck" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnExportCsv"
                    style="@style/TextAppearance.CocoCoin.Button"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_settings_button_secondary"
                    android:backgroundTint="@null"
                    android:text="匯出 CSV 報表"
                    android:textAllCaps="false"
                    android:textColor="#6E564F"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null"
                    tools:ignore="TouchTargetSizeCheck" />

                <Button
                    android:id="@+id/btnClearAllData"
                    style="@style/TextAppearance.CocoCoin.Button"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_settings_button_subtle_danger"
                    android:backgroundTint="@null"
                    android:text="清除所有記帳資料"
                    android:textAllCaps="false"
                    android:textColor="#9C6155"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null"
                    tools:ignore="TouchTargetSizeCheck" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
