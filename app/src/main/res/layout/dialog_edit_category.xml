<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <Button
        android:id="@+id/btnPickCategoryIcon"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="5dp"
        android:background="@drawable/bg_settings_button_secondary"
        android:backgroundTint="@null"
        android:text="自訂 icon"
        android:textAllCaps="false"
        android:textColor="#6E564F"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@null"
        tools:ignore="TouchTargetSizeCheck" />

    <EditText
        android:id="@+id/etCategoryName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="12dp"
        android:layout_marginRight="5dp"
        android:background="@drawable/bg_analysis_input"
        android:hint="輸入分類名稱"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp"
        android:textColor="#2F2A27"
        android:textSize="15sp" />

</LinearLayout>
