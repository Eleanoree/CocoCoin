<?xml version="1.0" encoding="utf-8"?>
<!--
    App 的「主框架」：
    - 中間是一個 Fragment 容器，用來切換不同頁面（首頁、分析、記帳、資產、設定）
    - 底部是導覽列
    使用 ConstraintLayout 讓 Fragment 容器填滿「導覽列以上的所有空間」
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6EFE8">

    <!-- ========== 中間內容區（Fragment） ========== -->
    <!--
        FragmentContainerView：專門放 Fragment 的容器
        根據使用者點擊底部導覽列，顯示不同的畫面（首頁、分析、記帳、資產、設定）

        約束條件（constraints）：
        - 頂部對齊父容器頂部（app:layout_constraintTop_toTopOf="parent"）
        - 底部對齊 bottomNav 的頂部（app:layout_constraintBottom_toTopOf="@id/bottomNav"）
        - 左右對齊父容器
        -> 這樣 Fragment 就會填滿「扣除底部導覽列以外的所有空間」
    -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 底部導覽列 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="#FFF9F4"
        app:cardCornerRadius="34dp"
        app:cardElevation="8dp"
        app:cardUseCompatPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingTop="6dp"
            android:paddingEnd="4dp"
            android:paddingBottom="6dp"
            android:weightSum="5">
            <!--android:weightSum="5" 總權重 = 5，每個子項目權重 = 1  均分 5 個按鈕-->

            <!-- 首頁 -->
            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/navHomeInner"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:id="@+id/bubbleHome"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_bottom_nav_selected_circle"
                        android:foregroundGravity="center">

                        <ImageView
                            android:id="@+id/iconHome"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_home"
                            app:tint="#A65B34" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/textHome"
                        style="@style/TextAppearance.CocoCoin.NavLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="首頁"
                        android:textColor="#A65B34"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- 分析 -->
            <LinearLayout
                android:id="@+id/navAnalysis"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/navAnalysisInner"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:id="@+id/bubbleAnalysis"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@android:color/transparent"
                        android:foregroundGravity="center">

                        <ImageView
                            android:id="@+id/iconAnalysis"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_analysis"
                            app:tint="#8C8B97" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/textAnalysis"
                        style="@style/TextAppearance.CocoCoin.NavLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="分析"
                        android:textColor="#8C8B97"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 記帳 -->
            <LinearLayout
                android:id="@+id/navAdd"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/navAddInner"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:id="@+id/bubbleAdd"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@android:color/transparent"
                        android:foregroundGravity="center">

                        <ImageView
                            android:id="@+id/iconAdd"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_add"
                            app:tint="#8C8B97" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/textAdd"
                        style="@style/TextAppearance.CocoCoin.NavLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="記帳"
                        android:textColor="#8C8B97"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 資產 -->
            <LinearLayout
                android:id="@+id/navAssets"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/navAssetsInner"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:id="@+id/bubbleAssets"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@android:color/transparent"
                        android:foregroundGravity="center">

                        <ImageView
                            android:id="@+id/iconAssets"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_assets"
                            app:tint="#8C8B97" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/textAssets"
                        style="@style/TextAppearance.CocoCoin.NavLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="資產"
                        android:textColor="#8C8B97"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 資產 -->
            <LinearLayout
                android:id="@+id/navSettings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/navSettingsInner"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:id="@+id/bubbleSettings"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@android:color/transparent"
                        android:foregroundGravity="center">

                        <ImageView
                            android:id="@+id/iconSettings"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_settings"
                            app:tint="#8C8B97" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/textSettings"
                        style="@style/TextAppearance.CocoCoin.NavLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="設定"
                        android:textColor="#8C8B97"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
