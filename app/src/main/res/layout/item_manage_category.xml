<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="5dp"
    android:layout_marginRight="5dp"
    android:layout_marginBottom="5dp"
    android:background="@drawable/bg_analysis_section_list"
    android:gravity="center_vertical"
    android:minHeight="58dp"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/tvManageCategoryIcon"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:background="@drawable/bg_account_icon_badge"
        android:gravity="center"
        android:text="🍽"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvManageCategoryName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:text="餐飲"
        android:textColor="#2F2A27"
        android:textSize="15sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnEditCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#DECECE"
        android:text="編輯"
        android:textAllCaps="false"
        android:textColor="#8F6E56"
        android:textSize="14sp"
        tools:ignore="TouchTargetSizeCheck" />

    <Button
        android:id="@+id/btnDeleteCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:backgroundTint="@null"
        android:text="刪除"
        android:textAllCaps="false"
        android:textColor="#A35A54"
        android:textSize="14sp"
        app:backgroundTint="#EFC8C8"
        tools:ignore="TouchTargetSizeCheck" />

</LinearLayout>
