<?xml version="1.0" encoding="utf-8"?>
<!-- 資產頁面 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6EFE8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            style="@style/TextAppearance.CocoCoin.PageTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="資產"
            android:textColor="#1E1E2A"
            android:textSize="28sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:backgroundTint="#FFFDFB"
            android:elevation="2dp"
            app:cardCornerRadius="22dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvBudgetMonth"
                    style="@style/TextAppearance.CocoCoin.CardTitleLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2026年3月預算設定"
                    android:textColor="#1E1E2A"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    style="@style/TextAppearance.CocoCoin.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_analysis_section_badge"
                    android:paddingStart="10dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="6dp"
                    android:text="本月規劃"
                    android:textColor="#A65B34"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_analysis_detail_panel"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextAppearance.CocoCoin.MetaLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="目前預算"
                        android:textColor="#9A8F87"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvCurrentBudget"
                        style="@style/TextAppearance.CocoCoin.MetricLarge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="NT$ 0"
                        android:textColor="#4C4642"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <EditText
                    android:id="@+id/etMonthlyBudget"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_assets_input"
                    android:gravity="center_vertical"
                    android:hint="輸入新的本月預算"
                    android:inputType="number"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="#2E2A2A"
                    android:textColorHint="#9A98A6" />

                <Button
                    android:id="@+id/btnSaveBudget"
                    style="@style/TextAppearance.CocoCoin.Button"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_analysis_primary_button"
                    android:backgroundTint="@null"
                    android:text="儲存本月預算"
                    android:textAllCaps="false"
                    android:textColor="#FFF8F3"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#FFFDFB"
            android:elevation="2dp"
            app:cardCornerRadius="22dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/TextAppearance.CocoCoin.CardTitleLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="帳戶餘額"
                    android:textColor="#1E1E2A"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_analysis_detail_panel"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextAppearance.CocoCoin.MetaLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="總資產"
                        android:textColor="#9A8F87"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvTotalAssets"
                        style="@style/TextAppearance.CocoCoin.MetricLarge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="NT$ 0"
                        android:textColor="#2E7D32"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_analysis_section_list"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        style="@style/TextAppearance.CocoCoin.Badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="帳戶列表"
                        android:textColor="#7C746D"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvEmptyAssets"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_analysis_summary"
                        android:gravity="center"
                        android:padding="14dp"
                        android:text="尚未新增帳戶"
                        android:textColor="#9A98A6"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:id="@+id/layoutAssetAccounts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_analysis_detail_panel"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextAppearance.CocoCoin.CardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="新增帳戶"
                        android:textColor="#3A3A48"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etAccountName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_assets_input"
                        android:gravity="center_vertical"
                        android:hint="例如：國泰銀行 / 現金 / 悠遊卡"
                        android:imeOptions="actionNext"
                        android:inputType="textCapSentences"
                        android:maxLines="1"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="#2E2A2A"
                        android:textColorHint="#9A98A6" />

                    <EditText
                        android:id="@+id/etAccountBalance"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_assets_input"
                        android:gravity="center_vertical"
                        android:hint="輸入目前餘額"
                        android:inputType="number"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="#2E2A2A"
                        android:textColorHint="#9A98A6" />

                    <Button
                        android:id="@+id/btnAddAccount"
                        style="@style/TextAppearance.CocoCoin.Button"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_analysis_primary_button"
                        android:backgroundTint="@null"
                        android:text="新增帳戶"
                        android:textAllCaps="false"
                        android:textColor="#FFF8F3"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
